generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model TeamMember {
  id         String    @id @db.Uuid
  name       String    @db.VarChar(255)
  email      String    @unique(map: "ix_team_members_email") @db.VarChar(255)
  role       String    @db.VarChar(100)
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  tickets    Ticket[]

  @@map("team_members")
}

model Ticket {
  id           String         @id @db.Uuid
  title        String         @db.VarChar(255)
  description  String
  status       ticketstatus
  priority     ticketpriority
  assigned_to  String?        @db.Uuid
  created_at   DateTime?      @default(now()) @db.Timestamptz(6)
  user_id      String?        @db.VarChar(255)
  tenant_id    String?        @db.VarChar(255)
  user_email   String?        @db.VarChar(255)
  source_app   String?        @db.VarChar(255)
  team_member  TeamMember?    @relation(fields: [assigned_to], references: [id], onUpdate: NoAction)

  @@index([assigned_to], map: "ix_tickets_assigned_to")
  @@index([created_at], map: "ix_tickets_created_at")
  @@index([status], map: "ix_tickets_status")
  @@map("tickets")
}

enum ticketpriority {
  LOW
  MEDIUM
  HIGH
}

enum ticketstatus {
  OPEN
  CLOSED
}
