generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  MANAGER
  USER
}

model TeamMember {
  id         String    @id @db.Uuid
  name       String    @db.VarChar(255)
  email      String    @unique(map: "ix_team_members_email") @db.VarChar(255)
  role       UserRole  @default(USER)
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  tickets    Ticket[]
  comments   TicketComment[]
  activities TicketActivity[]

  @@map("team_members")
}

model Ticket {
  id           String             @id @db.Uuid
  title        String             @db.VarChar(255)
  description  String
  state         ticketstate
  priority      ticketpriority
  assigned_to  String?            @db.Uuid
  created_at   DateTime?          @default(now()) @db.Timestamptz(6)
  user_id      String?            @db.VarChar(255)
  tenant_id    String?            @db.VarChar(255)
  user_email   String?            @db.VarChar(255)
  source_app   String?            @db.VarChar(255)
  type         tickettype         @default(TASK)
  story_points Int?
  labels       String[]           @db.VarChar(255)
  due_date     DateTime?          @db.Timestamptz(6)
  epic_link    String?            @db.VarChar(255)
  team_member  TeamMember?        @relation(fields: [assigned_to], references: [id], onUpdate: NoAction)
  attachments  TicketAttachment[]
  comments     TicketComment[]
  activities   TicketActivity[]

  @@index([assigned_to], map: "ix_tickets_assigned_to")
  @@index([created_at], map: "ix_tickets_created_at")
  @@index([state], map: "ix_tickets_state")
  @@map("tickets")
}

model TicketAttachment {
  id        String   @id @default(uuid()) @db.Uuid
  ticketId  String   @db.Uuid
  fileUrl   String
  fileName  String
  fileType  String
  createdAt DateTime @default(now()) @db.Timestamptz(6)

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@map("ticket_attachments")
}

model TicketComment {
  id        String   @id @default(uuid()) @db.Uuid
  ticketId  String   @db.Uuid
  authorId  String   @db.Uuid
  content   String
  createdAt DateTime @default(now()) @db.Timestamptz(6)

  ticket Ticket     @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author TeamMember @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@map("ticket_comments")
}

model TicketActivity {
  id        String   @id @default(uuid()) @db.Uuid
  ticketId  String   @db.Uuid
  actorId   String   @db.Uuid
  action    String
  details   String?
  createdAt DateTime @default(now()) @db.Timestamptz(6)

  ticket Ticket     @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  actor  TeamMember @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@map("ticket_activities")
}

enum ticketpriority {
  LOW
  MEDIUM
  HIGH
}

enum tickettype {
  BUG
  TASK
  STORY
  EPIC
}

enum ticketstate {
  OPEN
  IN_PROGRESS
  UNDER_PROGRESS
  COMPLETED
  CLOSED
}
